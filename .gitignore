# =============================================================================
# .gitignore — Reddit Tech News Bot
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — never commit these
# -----------------------------------------------------------------------------
config.py           # Contains Gmail credentials and bot settings


# -----------------------------------------------------------------------------
# BOT RUNTIME FILES — generated automatically, no need to track
# -----------------------------------------------------------------------------
seen_urls.txt       # Deduplication log — local to each machine
output/             # Daily CSV files

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]           # Compiled Python files (.pyc, .pyo, .pyd)
*.pyo
*.egg-info/
dist/
build/              # Also used by build.sh for Lambda packaging
.eggs/

# -----------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/

# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLE FILES
# -----------------------------------------------------------------------------
.env                # If you ever switch to a .env file for secrets
.env.local

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
.DS_Store           # Mac
Thumbs.db           # Windows
desktop.ini         # Windows

# -----------------------------------------------------------------------------
# IDE / EDITOR
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo